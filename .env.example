# Optional: Stripe (not required for cash-only bookings)
#STRIPE_SECRET_KEY=
#STRIPE_PUBLISHABLE_KEY=
#STRIPE_WEBHOOK_SECRET=

# Email / SMTP — example for iCloud Mail (recommended: create an app-specific password)
# iCloud SMTP: host=smtp.mail.me.com, port=587 (STARTTLS)
EMAIL_HOST=smtp.mail.me.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your@icloud.com
EMAIL_PASS=your-app-specific-password
# The from address shown on notification emails (optional)
FROM_EMAIL=your@icloud.com
# Business email receives notifications (set to your iCloud address)
BUSINESS_EMAIL=kaza_a@icloud.com

# Server
SERVER_URL=http://localhost:3000
PORT=3000
